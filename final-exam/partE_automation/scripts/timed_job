#!/bin/bash

OUTPUT_FILE="$1"

if [ -z "$OUTPUT_FILE" ]; then
    echo "Usage: timed_job <output_file>" >&2
    exit 1
fi

# Create directory for output file if it doesn't exist
mkdir -p "$(dirname "$OUTPUT_FILE")"

# Append timestamped line
echo "$(date '+%Y-%m-%d %H:%M:%S') - Timed job executed successfully by user: $(whoami)" >> "$OUTPUT_FILE"
